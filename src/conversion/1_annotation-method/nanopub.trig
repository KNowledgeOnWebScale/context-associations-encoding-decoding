@prefix np:    <http://www.nanopub.org/nschema#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix pav:   <http://purl.org/pav/> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:    <http://example.org/> .
@prefix this:  <http://example.org/nanopub/np1#> .

# --- Head graph: ties the nanopub parts together
this:Head {
  this:np1 a np:Nanopublication ;
    np:hasAssertion       this:Assertion ;
    np:hasProvenance      this:Provenance ;
    np:hasPublicationInfo this:PubInfo .
}

# --- Assertion graph: the actual claim
this:Assertion {
  ex:Paris ex:isCapitalOf ex:France .
}

# --- Provenance graph: where the claim came from / how it was produced
this:Provenance {
  this:Assertion
    prov:wasDerivedFrom <https://www.wikidata.org/entity/Q90> ;
    prov:wasAttributedTo ex:Alice ;
    prov:generatedAtTime "2026-02-19T10:30:00Z"^^xsd:dateTime .
}

# --- Publication info graph: metadata about publishing the nanopub
this:PubInfo {
  this:np1
    pav:createdBy ex:Alice ;
    dct:created "2026-02-19T10:31:00Z"^^xsd:dateTime ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> .
}
